{
	"name": "automattic/vip-security-boost-integration",
	"description": "Used for setting up development dependencies across the whole repository.",
	"homepage": "https://github.com/automattic/vip-security-boost-integration",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2",
		"spatie/mjml-php": "^1.2"
	},
	"require-dev": {
		"automattic/vipwpcs": "^3",
		"guzzlehttp/guzzle": "^7.9",
		"php-stubs/wordpress-tests-stubs": "^6.8",
		"phpcompatibility/phpcompatibility-wp": "^2",
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^9",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"wp-phpunit/wp-phpunit": "^6.5",
		"yoast/phpunit-polyfills": "3.0.0"
	},
	"autoload-dev": {
		"classmap": [
			"./modules/"
		]
	},
	"config": {
		"sort-packages": true,
		"platform": {
			"php": "8.2"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": false
		}
	},
	"scripts": {
		"lint": "./vendor/bin/phpcs --standard=.phpcs.xml.dist",
		"analyze": "./vendor/bin/phpstan analyse --memory-limit=1024M",
		"format": "./vendor/bin/phpcbf --standard=.phpcs.xml.dist",
		"phpcs": "./vendor/bin/phpcs",
		"test": "./bin/test.sh --php 8.2 --wp 6.8",
		"test-ci": "./bin/test.sh ",
		"test:multisite": "./bin/test.sh --php 8.2 --wp 6.8 --multisite 1",
		"test:integration": "./vendor/bin/phpunit --bootstrap tests/integration/bootstrap.php tests/integration/",
		"build-mjml": "./scripts/build-mjml.sh"
	}
}